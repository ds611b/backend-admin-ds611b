# ========================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ========================================

PORT=
HOST=
NODE_ENV=
DOCS_PATH=
LOG_LEVEL=

# ========================================
# BASE DE DATOS
# ========================================

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=

# ========================================
# EMAIL
# ========================================

# Modo de envío:
#   smtp → nodemailer (desarrollo local o servidores que permiten SMTP)
#   api  → Brevo HTTP API (Railway y PaaS que bloquean puertos SMTP)
EMAIL_MODE=smtp

# ── Modo SMTP (EMAIL_MODE=smtp) ──────────────────────────────────────────────
# Servidor SMTP (ej: smtp-relay.brevo.com, smtp.gmail.com)
SMTP_HOST=

# Puerto SMTP (587 = STARTTLS, 465 = SSL, 2525 = alternativo)
SMTP_PORT=587

# Usuario SMTP
SMTP_USER=

# Contraseña SMTP
SMTP_PASS=

# Remitente (ej: "ConnectPro <no-reply@tudominio.com>")
EMAIL_FROM=

# ── Modo API (EMAIL_MODE=api) ────────────────────────────────────────────────
# API Key v3 de Brevo (brevo.com → SMTP & API → API Keys, empieza con xkeysib-)
BREVO_API_KEY=

# Correo remitente verificado en Brevo
EMAIL_FROM_ADDRESS=

# ========================================
# FRONTEND
# ========================================

# URL base del frontend (para links en correos)
APP_URL=http://localhost:4200
